rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPERS =====
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    // author ή admin μπορεί να δημιουργεί περιεχόμενο
    function isAuthor() {
      return isSignedIn() && (getRole() == 'author' || getRole() == 'admin');
    }

    // ===== USERS =====
    // Admin: πλήρης πρόσβαση.
    // Χρήστης: μπορεί να δημιουργήσει ΜΟΝΟ το δικό του doc, και ΜΟΝΟ αν
    //   υπάρχει invite για το email του με τον ίδιο ρόλο (invite claiming).
    match /users/{uid} {
      allow read:   if request.auth.uid == uid || isAdmin();
      allow create: if isAdmin()
                    || (isSignedIn()
                        && request.auth.uid == uid
                        && get(/databases/$(database)/documents/invites/$(request.auth.token.email.lower())).data.role
                           == request.resource.data.role);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== INVITES =====
    // Admin: πλήρης πρόσβαση.
    // Logged-in χρήστης: μπορεί να διαβάσει και να διαγράψει ΜΟΝΟ το δικό του invite
    //   (το doc ID είναι το lowercase email).
    match /invites/{email} {
      allow read:          if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == email);
      allow create, update: if isAdmin();
      allow delete:        if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == email);
    }

    // ===== ARTICLES =====
    match /articles/{docId} {
      allow read: if resource.data.status == 'published' || isAdmin()
                  || (isAuthor() && resource.data.authorUid == request.auth.uid);

      allow create: if isAdmin()
                    || (isAuthor()
                        && request.resource.data.status == 'pending'
                        && request.resource.data.authorUid == request.auth.uid);

      allow update: if isAdmin()
                    || (isAuthor()
                        && resource.data.authorUid == request.auth.uid
                        && !('status' in request.resource.data.diff(resource.data).affectedKeys().intersection(['status']))
                        );

      allow delete: if isAdmin()
                    || (isAuthor() && resource.data.authorUid == request.auth.uid);
    }

    // ===== ANNOUNCEMENTS =====
    match /announcements/{docId} {
      allow read: if resource.data.status == 'published' || isAdmin()
                  || (isAuthor() && resource.data.authorUid == request.auth.uid);

      allow create: if isAdmin()
                    || (isAuthor()
                        && request.resource.data.status == 'pending'
                        && request.resource.data.authorUid == request.auth.uid);

      allow update: if isAdmin()
                    || (isAuthor() && resource.data.authorUid == request.auth.uid
                        && !('status' in request.resource.data.diff(resource.data).affectedKeys()));

      allow delete: if isAdmin()
                    || (isAuthor() && resource.data.authorUid == request.auth.uid);
    }

    // ===== GALLERY =====
    match /gallery/{docId} {
      allow read: if resource.data.status == 'published' || isAdmin()
                  || (isAuthor() && resource.data.uploadedByUid == request.auth.uid);

      allow create: if isAdmin()
                    || (isAuthor()
                        && request.resource.data.status == 'pending'
                        && request.resource.data.uploadedByUid == request.auth.uid);

      allow update: if isAdmin();

      allow delete: if isAdmin()
                    || (isAuthor() && resource.data.uploadedByUid == request.auth.uid);
    }

    // ===== ACTIONS =====
    match /actions/{docId} {
      allow read: if resource.data.status == 'published' || isAdmin()
                  || (isAuthor() && resource.data.authorUid == request.auth.uid);

      allow create: if isAdmin()
                    || (isAuthor()
                        && request.resource.data.status == 'pending'
                        && request.resource.data.authorUid == request.auth.uid);

      allow update: if isAdmin()
                    || (isAuthor()
                        && resource.data.authorUid == request.auth.uid
                        && !('status' in request.resource.data.diff(resource.data).affectedKeys().intersection(['status']))
                        );

      allow delete: if isAdmin()
                    || (isAuthor() && resource.data.authorUid == request.auth.uid);
    }

    // ===== CONTACT MESSAGES =====
    match /contactMessages/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ===== VOLUNTEERS =====
    match /volunteers/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
